
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user registered in the application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier (Firebase Auth UID)."
        },
        "username": {
          "type": "string",
          "description": "Chosen username."
        },
        "dateOfBirth": {
          "type": "string",
          "description": "User's date of birth.",
          "format": "date"
        },
        "gender": {
          "type": "string",
          "description": "User's gender."
        },
        "sequentialId": {
          "type": "number",
          "description": "Numeric ID starting from 1."
        },
        "isAdmin": {
          "type": "boolean",
          "description": "True if the user is the first user (User 1)."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of account creation.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "username",
        "dateOfBirth",
        "gender",
        "sequentialId",
        "isAdmin",
        "createdAt"
      ]
    },
    "Counter": {
      "title": "Counter",
      "type": "object",
      "properties": {
        "count": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profile data."
    },
    "/counters/{counterId}": {
      "schema": { "$ref": "#/backend/entities/Counter" },
      "description": "Internal counters for sequential IDs."
    }
  }
}
