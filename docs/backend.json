
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user registered in the application.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "description": { "type": "string" },
        "dateOfBirth": { "type": "string", "format": "date" },
        "gender": { "type": "string" },
        "sequentialId": { "type": "number" },
        "coins": { "type": "number" },
        "isAdmin": { "type": "boolean" },
        "isVerified": { "type": "boolean" },
        "isPremium": { "type": "boolean" },
        "premiumType": { "type": "string", "enum": ["none", "monthly", "lifetime"] },
        "premiumStatus": { "type": "string", "enum": ["none", "active", "cancelled"] },
        "premiumExpiry": { "type": "string", "format": "date-time" },
        "lastPremiumGrant": { "type": "string", "format": "date-time" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "pastUsernames": { "type": "array", "items": { "type": "string" } },
        "moderationHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "reason": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "isBanned": { "type": "boolean" },
        "banType": { "type": "string", "enum": ["none", "warning", "temp-1", "temp-7", "perm"] },
        "banReason": { "type": "string" },
        "banExpiry": { "type": "string", "format": "date-time" },
        "banOffensiveContent": { "type": "string" },
        "needsToAcceptTerms": { "type": "boolean" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "sequentialId", "coins", "isAdmin", "createdAt"]
    },
    "Friendship": {
      "title": "Friendship",
      "type": "object",
      "properties": {
        "user1": { "type": "string" },
        "user2": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted"] },
        "requestSentBy": { "type": "string" },
        "bestFriendOf": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["user1", "user2", "status", "requestSentBy", "createdAt"]
    },
    "Follow": {
      "title": "Follow",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["followerId", "followingId", "createdAt"]
    },
    "VerificationRequest": {
      "title": "VerificationRequest",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "denied"] },
        "requestedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "username", "status", "requestedAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["coin_purchase", "premium_purchase", "username_change", "premium_grant"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reporterId": { "type": "string" },
        "targetUserId": { "type": "string" },
        "reason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/User" }, "description": "User profiles." },
    "/friendships/{friendshipId}": { "schema": { "$ref": "#/backend/entities/Friendship" }, "description": "Social connections." },
    "/follows/{followId}": { "schema": { "$ref": "#/backend/entities/Follow" }, "description": "One-way following relationships." },
    "/verificationRequests/{requestId}": { "schema": { "$ref": "#/backend/entities/VerificationRequest" }, "description": "Requests for verification badge." },
    "/transactions/{transactionId}": { "schema": { "$ref": "#/backend/entities/Transaction" }, "description": "Financial and account logs." },
    "/reports/{reportId}": { "schema": { "$ref": "#/backend/entities/Report" }, "description": "Misconduct reports." },
    "/counters/{counterId}": { "schema": { "type": "object", "properties": { "count": { "type": "number" } } }, "description": "System counters." }
  }
}
