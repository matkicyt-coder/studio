
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic sign-in check
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if user is an administrator
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // User profile rules
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Misconduct report rules
    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, list, update, delete: if isAdmin();
    }

    // Internal system counters
    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }

    // Social connection rules - Deployment Trigger: v1.0.1
    match /friendships/{friendshipId} {
      // Allow listing friendships if signed in
      allow read, list: if isSignedIn();
      
      // Allow creation if the user is part of the friendship
      allow create: if isSignedIn() && (
        request.resource.data.user1 == request.auth.uid || 
        request.resource.data.user2 == request.auth.uid
      );
      
      // Allow updates/deletes if the user is one of the participants
      allow update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.user1 || 
        request.auth.uid == resource.data.user2
      );
    }
  }
}
