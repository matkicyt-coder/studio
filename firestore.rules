
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() && 
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true) ||
          (existsGroup(/databases/$(database)/documents/users, "uid", request.auth.uid) && getGroup(/databases/$(database)/documents/users, "uid", request.auth.uid)[0].data.isAdmin == true)
        );
    }

    // Helper to check if a user is the owner regardless of whether ID is UID or SequentialID
    function isOwner(userId) {
      return isSignedIn() && (
        request.auth.uid == userId || 
        (resource != null && resource.data.uid == request.auth.uid) ||
        (request.resource != null && request.resource.data.uid == request.auth.uid)
      );
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
    }

    match /friendships/{friendshipId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.uid || isOwner(resource.data.user1) || isOwner(resource.data.user2));
      allow delete: if isSignedIn() && (isOwner(resource.data.user1) || isOwner(resource.data.user2));
    }

    match /follows/{followId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && isOwner(resource.data.followerId);
    }

    match /verificationRequests/{requestId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow list: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn();
      allow list: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, list, update, delete: if isAdmin();
    }

    match /counters/{counterId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
