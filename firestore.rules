
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Optimized isAdmin check for performance in list rules
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /users/{userId} {
      // Users can see themselves, admins can see everyone, 
      // and User #1 is always visible (as the system sender)
      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        isAdmin() || 
        resource.data.sequentialId == 1
      );
      
      // Explicit list rule to allow admins to see all users
      // or standard users to find the admin by sequentialId
      allow list: if isSignedIn() && (
        isAdmin() ||
        (request.query.limit <= 10 && resource.data.sequentialId == 1)
      );
      
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }

    match /messages/{messageId} {
      // Explicitly split read into get and list for the firestore query optimizer
      allow get: if isSignedIn() && (
        resource.data.receiverId == request.auth.uid || 
        resource.data.senderId == request.auth.uid ||
        isAdmin()
      );
      
      allow list: if isSignedIn() && (
        isAdmin() ||
        resource.data.receiverId == request.auth.uid || 
        resource.data.senderId == request.auth.uid
      );
      
      allow create: if isSignedIn();
      
      allow update, delete: if isSignedIn() && (
        isAdmin() || 
        resource.data.receiverId == request.auth.uid
      );
    }
  }
}
